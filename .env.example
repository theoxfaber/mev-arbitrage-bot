# ══════════════════════════════════════════════════════════════════════════════
# MEV Arbitrage Engine — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your own values:
#   cp .env.example .env

# ── RPC Endpoints ─────────────────────────────────────────────────────────────
# HTTP (simulation + submission). Provide at least one; a second enables fallback.
ETH_RPC_URL_1=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_1
ETH_RPC_URL_2=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_2

# WebSocket (mempool scanning). At least one required; second enables multi-RPC racing.
ETH_WSS_URL_1=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_WSS_1
ETH_WSS_URL_2=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_WSS_2

# ── Wallets ───────────────────────────────────────────────────────────────────
# Comma-separated private keys for executor wallets.
# Must be pre-funded with ETH for gas + miner rewards.
PRIVATE_KEYS=0xYourPrivateKey1,0xYourPrivateKey2

# Flashbots auth signer (does NOT need funds — used for relay reputation only).
FLASHBOTS_AUTH_KEY=0xYourFlashbotsAuthKey

# ── Contract ──────────────────────────────────────────────────────────────────
# Deployed ArbitrageExecutor contract address.
EXECUTOR_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# ── Bidding Strategy ──────────────────────────────────────────────────────────
# All values in basis points (1 bps = 0.01%, 10000 bps = 100%)
MIN_PROFIT_BPS=3000               # 30% minimum acceptable profit
BASE_MINER_REWARD_BPS=2500        # 25% miner reward at reference gas price
MAX_MINER_REWARD_BPS=6500         # 65% hard ceiling on miner reward
REFERENCE_GAS_PRICE_GWEI=20       # Gas price at which base reward applies

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CIRCUIT_BREAKER_WINDOW_MINUTES=60
CIRCUIT_BREAKER_MAX_LOSS_WEI=500000000000000000  # 0.5 ETH

# ── Kill Switch ───────────────────────────────────────────────────────────────
# Set to "true" to immediately halt all execution
KILL_SWITCH=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                    # trace, debug, info, warn, error
LOG_JSON=false                    # true for JSON log output (production)

# ── Metrics ───────────────────────────────────────────────────────────────────
METRICS_PORT=9090                 # Prometheus scrape port (0 to disable)

# ── Telegram Alerts (optional) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Dry Run ───────────────────────────────────────────────────────────────────
DRY_RUN=false                     # Simulate but don't submit bundles
